      @keyframes fadeDownHeadline {
        0% {
            opacity: 0;
            transform: translate(-50%, -70%);
        }
        100% {
            opacity: 1;
            transform: translate(-50%, -50%);
        }
    }
    
    @keyframes fadeDown {
        0% {
            opacity: 0;
            transform: translate(0%, -50%);
        }
        100% {
            opacity: 1;
            transform: translate(0%, 0%);
        }
    }
    

       @keyframes scale {
        0% {
            scale: 0;
        }
        100% {
            scale: 1;
        }
    }